# ─── DECIDO ortam değişkenleri ───
# Bu dosyayı .env olarak kopyala ve değerleri doldur.

# ─── LLM sağlayıcı (çoklu seçim) ───
# Sağlayıcıyı seç: openrouter | anthropic | openai
# Boş bırakırsan hangi anahtar doluysa ona göre otomatik seçilir.
LLM_PROVIDER=openrouter

# OpenRouter (önerilen başlangıç — içinden Claude/GPT/Gemini çağrılabilir)
OPENROUTER_API_KEY=sk-or-...

# Anthropic (doğrudan Claude — anahtarın olunca)
ANTHROPIC_API_KEY=

# OpenAI (doğrudan — istersen)
OPENAI_API_KEY=

# Model adları (boş bırakırsan sağlayıcıya göre makul varsayılan kullanılır)
# OpenRouter slug biçimi: "saglayici/model"
#   enrich (ucuz)      örn: openai/gpt-4o-mini  ·  ücretsiz: google/gemini-2.0-flash-exp:free
#   compare (güçlü)    örn: anthropic/claude-3.7-sonnet  ·  ekonomik: openai/gpt-4o-mini
ENRICH_MODEL=
COMPARE_MODEL=
# TL;DR özeti için model (boşsa COMPARE_MODEL'e düşer)
SUMMARY_MODEL=

# Postgres bağlantısı (Neon / Supabase / yerel)
# Yerel hızlı test için SQLite alternatifi: README'ye bak.
DATABASE_URL=postgresql://user:pass@host:5432/decido?sslmode=require

# Yakalama endpoint'ini koruyan paylaşılan sır (eklenti + bot bunu gönderir)
DECIDO_API_KEY=uzun-rastgele-bir-sir-uret

# Vercel Cron fiyat kontrolünü korur (Vercel otomatik "Authorization: Bearer <CRON_SECRET>" ekler)
CRON_SECRET=baska-uzun-rastgele-bir-sir

# PWA arayüzü girişi için passphrase (tek kullanıcı)
DECIDO_APP_PASSWORD=kendine-bir-parola-belirle

# Telegram bot (Faz 1 mobil yakalama)
TELEGRAM_BOT_TOKEN=123456:ABC...
# Sadece bu Telegram kullanıcı ID'sinden gelen mesajlar kabul edilir (kendi ID'in)
TELEGRAM_ALLOWED_USER_ID=123456789

# Uygulamanın kendi public URL'i (bot yanıtları / linkler için)
NEXT_PUBLIC_APP_URL=http://localhost:3000
